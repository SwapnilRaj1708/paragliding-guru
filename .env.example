# ---------------------------------------------------------------------------
# SMTP configuration for the contact form (nodemailer)
#
# Copy this file to `.env.local` and fill in real credentials.
# `.env.local` is gitignored — never commit real secrets.
#
# Common providers:
#   - Gmail (via App Password): host = smtp.gmail.com, port = 465, secure = true
#   - Zoho Mail:                host = smtp.zoho.in,   port = 465, secure = true
#   - SendGrid:                 host = smtp.sendgrid.net, port = 587, user = "apikey"
#   - Mailgun / Postmark / Brevo / Amazon SES: see their SMTP docs
# ---------------------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# Optional. Leave unset to auto-detect (true for port 465, false otherwise).
# SMTP_SECURE=true
SMTP_USER=your-smtp-username@example.com
SMTP_PASSWORD=your-smtp-password-or-app-password

# The "From" address shown to the recipient. Usually must match SMTP_USER
# (or a verified alias) or your provider will reject the send.
MAIL_FROM="PG Gurukul Website <no-reply@pggurukul.com>"

# Where contact-form submissions are delivered.
MAIL_TO=info@pggurukul.com
